# Burg Report Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Anthropic (Claude API) — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# Supabase — get from supabase.com > Project Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Airtable — get from airtable.com/create/tokens
AIRTABLE_TOKEN=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_GRAND_CRUS_TABLE=Grand Crus
AIRTABLE_VINTAGES_TABLE=Vintage Ratings

# Wine-Searcher (when approved)
WINE_SEARCHER_KEY=

# Frontend
FRONTEND_URL=https://burgreport.com
